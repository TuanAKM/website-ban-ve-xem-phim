@{ ViewData["Title"] = "Soát Vé Nhập Mã"; }
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 rounded-4">
                <div class="card-body p-5 text-center">
                    <h2 class="text-primary mb-4"><i class="bi bi-qr-code-scan"></i> KIỂM KÊ & SOÁT VÉ (CHECK-IN)</h2>
                    
                    @if (TempData["Message"] != null)
                    {
                        var isC = (bool?)TempData["IsComplete"] == true;
                        <div class="alert @(isC ? "alert-success" : "alert-danger") fs-5 fw-bold">
                            @if(isC) { <i class="bi bi-check-circle"></i> } else { <i class="bi bi-exclamation-triangle"></i> }
                            @TempData["Message"]
                        </div>
                    }

                    <form id="checkInForm" asp-action="Scan" method="post" class="mt-4">
                        <div class="input-group input-group-lg mb-3">
                            <input type="text" name="maVe" class="form-control fw-bold fs-4 text-center" 
                                   placeholder="Nhập mã vé hoặc quét QR code" 
                                   value="@ViewBag.SearchCode" autofocus autocomplete="off" />
                            <button class="btn btn-primary px-5 fw-bold" type="submit">XÁC NHẬN</button>
                        </div>
                    </form>

                    @if(!string.IsNullOrEmpty(ViewBag.SearchCode))
                    {
                        <div class="mt-4">
                            <a asp-action="Print" asp-route-maVe="@ViewBag.SearchCode" target="_blank" class="btn btn-outline-dark fw-bold rounded-pill px-4">
                                <i class="bi bi-printer"></i> IN VÉ LẠI (THERMAL FORMAT)
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById("checkInForm").addEventListener("submit", async function(e) {
            e.preventDefault(); // Tạm dừng submit
            
            const form = this;
            const btn = form.querySelector('button[type="submit"]');
            const maVe = form.querySelector('input[name="maVe"]').value.trim();
            
            if (!maVe) {
                form.submit();
                return;
            }

            btn.disabled = true;
            btn.innerHTML = `<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Đang kiểm tra...`;

            try {
                // Gọi API kiểm tra độ tuổi
                const res = await fetch(`/Admin/Ticket/CheckAgeInfo?maVe=${encodeURIComponent(maVe)}`);
                const data = await res.json();

                if (data.hasAgeRating) {
                    const confirmed = confirm(`⚠️ CẢNH BÁO: Phim này được dán nhãn [${data.rating}].\n\nYêu cầu NHÂN VIÊN kiểm tra CCCD/CMND của khách hàng để đảm bảo độ tuổi.\n\nNhấn [OK] nếu khách hàng đã đủ tuổi và bạn cho phép vào rạp.`);
                    if (!confirmed) {
                        btn.disabled = false;
                        btn.innerHTML = "XÁC NHẬN";
                        return; // Hủy check-in
                    }
                }
                
                // Trực tiếp submit form khi đã qua vòng kiểm tra
                form.submit();
            } catch (err) {
                console.error(err);
                form.submit(); // Lỗi mạng thì cứ cho submit để server tự lo
            }
        });
    </script>
}

@model MiniCinema.DTOs.UserEditDto
@{ ViewData["Title"] = "Sửa Thông Tin User"; }
<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow border-0 rounded-4">
                <div class="card-body p-4">
                    <h3 class="mb-4 text-warning fw-bold text-center"><i class="bi bi-pencil-square"></i> SỬA THÔNG TIN USER</h3>
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="mb-3">
                            <label class="form-label text-muted fw-bold">Tài khoản (Không đổi)</label>
                            <input asp-for="Username" class="form-control bg-light text-secondary" readonly />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Họ tên</label>
                            <input asp-for="HoTen" class="form-control" />
                            <span asp-validation-for="HoTen" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Số điện thoại</label>
                            <input asp-for="PhoneNumber" class="form-control" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Email</label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        
                        <hr class="mt-4 border-warning">
                        <p class="text-muted small mb-2"><i class="bi bi-shield-lock-fill"></i> NẾU muốn đổi mật khẩu mới cho user này, hãy nhập vào đây. Còn không, hãy để trống ô bên dưới.</p>
                        <div class="mb-4">
                            <input asp-for="NewPassword" class="form-control border-danger border-2" type="text" placeholder="Gõ Pass mới..." />
                        </div>

                        <button type="submit" class="btn btn-warning w-100 btn-lg rounded-pill fw-bold mb-2 text-white">Lưu Thay Đổi</button>
                        <a asp-action="Index" class="btn btn-light w-100 rounded-pill">Quay Lại</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }

@model MiniCinema.Models.Phim
@{ ViewData["Title"] = "Chi Tiết Phim"; }
<div class="container mt-5">
    <div class="card shadow border-0 rounded-4 overflow-hidden">
        <div class="row g-0">
            <div class="col-md-4 bg-dark text-white p-5 d-flex flex-column justify-content-center align-items-center">
                <h1 class="display-3"><i class="bi bi-film"></i></h1>
                <h3 class="mt-3 text-center">@Model.TenPhim</h3>
                <span class="badge bg-warning text-dark mt-2 fs-6">@Model.DinhDang | @Model.NhanDoTuoi</span>
            </div>
            <div class="col-md-8 p-5">
                <h2 class="text-primary border-bottom pb-2 mb-4">Thông Số Kỹ Thuật</h2>
                <div class="row mb-3 fs-5">
                    <div class="col-sm-4 text-muted fw-bold">Mã ID Phim:</div>
                    <div class="col-sm-8">@Model.MaPhim</div>
                </div>
                <div class="row mb-3 fs-5">
                    <div class="col-sm-4 text-muted fw-bold">Thể Loại:</div>
                    <div class="col-sm-8">@Model.TheLoai</div>
                </div>
                <div class="row mb-3 fs-5">
                    <div class="col-sm-4 text-muted fw-bold">Thời Lượng:</div>
                    <div class="col-sm-8"><span class="text-success fw-bold">@Model.ThoiLuong phút</span></div>
                </div>
                
                <div class="mt-5">
                    <a asp-action="Edit" asp-route-id="@Model.MaPhim" class="btn btn-warning rounded-pill px-4 fw-bold me-2"><i class="bi bi-pencil"></i> Chỉnh Sửa</a>
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Đóng</a>
                </div>
            </div>
        </div>
    </div>
</div>

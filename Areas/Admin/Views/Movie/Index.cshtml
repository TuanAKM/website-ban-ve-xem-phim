@model IEnumerable<MiniCinema.Models.Phim>
@{ ViewData["Title"] = "Quản lý Phim"; }
<div class="container mt-4">
    <h2>Danh sách phim</h2>
    <a asp-action="Create" class="btn btn-primary mb-3">Thêm mới</a>
    <table class="table table-bordered table-striped">
        <thead>
            <tr><th>Mã Phim</th><th>Tên Phim</th><th>Thời Lượng</th><th>Thể Loại</th><th>Action</th></tr>
        </thead>
        <tbody>
            @foreach(var item in Model) {
            <tr>
                <td>@item.MaPhim</td>
                <td>@item.TenPhim</td>
                <td>@item.ThoiLuong phút</td>
                <td>@item.TheLoai</td>
                <td>
                    <div class="btn-group" role="group">
                        <a asp-action="Details" asp-route-id="@item.MaPhim" class="btn btn-sm btn-info text-white"><i class="bi bi-info-circle"></i> Chi tiết</a>
                        <a asp-action="Edit" asp-route-id="@item.MaPhim" class="btn btn-sm btn-warning text-dark"><i class="bi bi-pencil-square"></i> Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.MaPhim" class="btn btn-sm btn-danger"><i class="bi bi-trash"></i> Xóa</a>
                    </div>
                </td>
            </tr>
            }
        </tbody>
    </table>
</div>

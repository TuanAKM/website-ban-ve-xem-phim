@model MiniCinema.Models.PhongChieu
@{ ViewData["Title"] = "Thiết Lập Ghế"; }

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary m-0"><i class="bi bi-grid-3x3"></i> Thiết Lập Ghế - Phòng @Model.TenPhong</h2>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Quay Lại</a>
    </div>

    <div class="alert alert-info">
        <i class="bi bi-info-circle-fill"></i> Nhấn vào từng ghế bên dưới để thay đổi Loại ghế và Trạng thái (Ví dụ: Khóa ghế hỏng).
    </div>

    <!-- Màn hình chiếu -->
    <div class="text-center mb-5 mt-4">
        <div class="bg-secondary text-white fw-bold py-2 rounded shadow-sm mx-auto w-75" style="transform: perspective(200px) rotateX(-5deg);">
            MÀN HÌNH CHÍNH
        </div>
        <div class="text-muted mt-2 small">Screen Direction</div>
    </div>

    <!-- Sơ đồ ghế -->
    <div class="row justify-content-center">
        <div class="col-md-10 text-center">
            @{
                if (Model.Ghes != null && Model.Ghes.Any())
                {
                    // Group ghế theo ký tự đầu tiên (A, B, C...)
                    var rows = Model.Ghes.GroupBy(g => g.MaGhe.Substring(g.MaGhe.IndexOf('-') + 1, 1)).OrderBy(g => g.Key);
                    
                    foreach (var row in rows)
                    {
                        <div class="d-flex justify-content-center align-items-center mb-2 gap-2">
                            <strong class="text-muted me-3" style="width: 20px;">@row.Key</strong>
                            <div class="d-flex gap-2 justify-content-center flex-wrap">
                                @foreach (var seat in row.OrderBy(s => s.MaGhe))
                                {
                                    string seatColor = "bg-secondary"; // Mặc định Thường
                                    string icon = "";
                                    
                                    // Tô màu theo Loại ghế nếu chưa hỏng
                                    if (seat.TrangThai == MiniCinema.Models.TrangThaiGhe.Hong)
                                    {
                                        seatColor = "bg-dark"; // Hỏng
                                        icon = "<i class='bi bi-x'></i>";
                                    }
                                    else if (seat.LoaiGhe == MiniCinema.Models.LoaiGhe.Vip)
                                        seatColor = "bg-danger";
                                    else if (seat.LoaiGhe == MiniCinema.Models.LoaiGhe.Doi)
                                        seatColor = "bg-info text-dark"; // text-dark cho ghế đôi dễ nhìn
                                    
                                    string seatIdNum = seat.MaGhe.Substring(seat.MaGhe.IndexOf('-') + 2); // Chỉ lấy số ghế
                                    
                                    <div class="seat-admin p-2 rounded shadow-sm border border-light @seatColor text-white text-center fw-bold" 
                                         style="width: 45px; height: 45px; cursor: pointer; user-select: none;"
                                         data-id="@seat.MaGhe" 
                                         data-type="@((int)seat.LoaiGhe)" 
                                         data-status="@((int)seat.TrangThai)"
                                         onclick="openSeatModal(this)">
                                        @if(string.IsNullOrEmpty(icon)) {
                                            @seatIdNum
                                        } else {
                                            @Html.Raw(icon)
                                        }
                                    </div>
                                }
                            </div>
                            <strong class="text-muted ms-3" style="width: 20px;">@row.Key</strong>
                        </div>
                    }
                }
            }
        </div>
    </div>

    <!-- Chú thích -->
    <div class="d-flex justify-content-center gap-4 mt-5 border-top pt-4">
        <div class="d-flex align-items-center gap-2"><div class="rounded bg-secondary" style="width: 20px; height: 20px;"></div> Thường</div>
        <div class="d-flex align-items-center gap-2"><div class="rounded bg-danger" style="width: 20px; height: 20px;"></div> VIP</div>
        <div class="d-flex align-items-center gap-2"><div class="rounded bg-info" style="width: 20px; height: 20px;"></div> Đôi (Couple)</div>
        <div class="d-flex align-items-center gap-2"><div class="rounded bg-dark d-flex justify-content-center align-items-center text-white" style="width: 20px; height: 20px;"><i class="bi bi-x" style="font-size: 14px;"></i></div> Hỏng (Khóa)</div>
    </div>
</div>

<!-- Modal cập nhật ghế -->
<div class="modal fade" id="seatModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header bg-primary text-white border-0">
                <h5 class="modal-title fw-bold"><i class="bi bi-gear-fill"></i> Cấu Hình Ghế: <span id="modalSeatTitle"></span></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="modalSeatId" />
                
                <div class="mb-3">
                    <label class="form-label fw-bold">Phân Loại Ghế</label>
                    <select id="modalSeatType" class="form-select">
                        <option value="0">Ghế Thường</option>
                        <option value="2">Ghế VIP</option>
                        <option value="1">Ghế Đôi (Couple)</option>
                    </select>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Trạng Thái Kỹ Thuật</label>
                    <select id="modalSeatStatus" class="form-select">
                        <option value="0">Bình thường (Trống)</option>
                        <option value="3" class="text-danger">Báo hỏng (Khóa ghế)</option>
                    </select>
                    <div class="form-text text-danger mt-2">
                        <i class="bi bi-exclamation-triangle"></i> Lưu ý: Khi báo hỏng, ghế này sẽ không thể được bán ở tất cả các suất chiếu tương lai tại phòng này.
                    </div>
                </div>
            </div>
            <div class="modal-footer border-top-0 pt-0">
                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary rounded-pill px-4 fw-bold" onclick="saveSeatSettings()">
                    <span id="saveSpinner" class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
                    Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .seat-admin {
        transition: transform 0.1s, opacity 0.2s;
    }
    .seat-admin:hover {
        transform: scale(1.1);
        opacity: 0.8;
    }
</style>

@section Scripts {
    <script>
        let seatModal;
        
        document.addEventListener("DOMContentLoaded", function() {
            const modalEl = document.getElementById('seatModal');
            document.body.appendChild(modalEl); // Đưa Modal ra ngoài cùng <body> để không bị đè bởi z-index của Layout
            seatModal = new bootstrap.Modal(modalEl);
        });

        function openSeatModal(element) {
            const seatId = element.getAttribute("data-id");
            const type = element.getAttribute("data-type");
            const status = element.getAttribute("data-status");

            document.getElementById("modalSeatTitle").innerText = seatId;
            document.getElementById("modalSeatId").value = seatId;
            document.getElementById("modalSeatType").value = type;
            
            // Nếu ghế đang Trong/Đang Chọn/Đã Bán thì gộp chung về Bình Thường (0) quản lý
            // Trừ khi nó đang Hỏng (3)
            document.getElementById("modalSeatStatus").value = (status == "3") ? "3" : "0";

            seatModal.show();
        }

        async function saveSeatSettings() {
            const seatId = document.getElementById("modalSeatId").value;
            const typeValue = parseInt(document.getElementById("modalSeatType").value);
            const statusValue = parseInt(document.getElementById("modalSeatStatus").value);

            const btnSpinner = document.getElementById("saveSpinner");
            btnSpinner.classList.remove("d-none");

            try {
                const response = await fetch('/Admin/Room/UpdateSeat', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        MaGhe: seatId,
                        LoaiGhe: typeValue,
                        TrangThaiGhe: statusValue
                    })
                });

                const data = await response.json();
                
                if (data.success) {
                    // Update UI manually to avoid full reload
                    const seatEl = document.querySelector(`.seat-admin[data-id='${seatId}']`);
                    seatEl.setAttribute("data-type", typeValue);
                    seatEl.setAttribute("data-status", statusValue);

                    // Reset styling classes
                    seatEl.classList.remove("bg-secondary", "bg-danger", "bg-info", "bg-dark", "text-dark");
                    
                    let newName = seatId.substring(seatId.indexOf('-') + 2);

                    if (statusValue === 3) {
                        seatEl.classList.add("bg-dark");
                        seatEl.innerHTML = "<i class='bi bi-x'></i>";
                    } else {
                        if (typeValue === 2) seatEl.classList.add("bg-danger");
                        else if (typeValue === 1) seatEl.classList.add("bg-info", "text-dark");
                        else seatEl.classList.add("bg-secondary");
                        
                        seatEl.innerHTML = newName;
                    }

                    seatModal.hide();
                } else {
                    alert("Lỗi: " + data.message);
                }
            } catch (err) {
                console.error(err);
                alert("Đã xảy ra lỗi mạng. Vui lòng thử lại!");
            } finally {
                btnSpinner.classList.add("d-none");
            }
        }
    </script>
}

@model IEnumerable<MiniCinema.Models.PhongChieu>
@{ ViewData["Title"] = "Quản Lý Cấu Hình Phòng"; }
<div class="container mt-4">
    <h2 class="text-primary mb-4">Cấu Hình Phòng Chiếu & Sơ Đồ Ghế</h2>
    <a asp-action="Create" class="btn btn-primary mb-3"><i class="bi bi-plus-circle"></i> Tạo Phòng Mới</a>
    <table class="table table-bordered table-striped shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Mã Phòng</th>
                <th>Tên Phòng</th>
                <th>Phân Loại</th>
                <th>Tổng Số Ghế</th>
                <th>Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any()) {
                @foreach (var p in Model) {
                    <tr>
                        <td class="fw-bold">@p.MaPhong</td>
                        <td>@p.TenPhong</td>
                        <td><span class="badge bg-secondary">@p.LoaiPhong</span></td>
                        <td><span class="text-success fw-bold">@p.TongSoGhe</span> ghế</td>
                        <td>
                            <div class="btn-group" role="group">
                                <a asp-action="Details" asp-route-id="@p.MaPhong" class="btn btn-sm btn-info text-white"><i class="bi bi-info-circle"></i> Chi tiết</a>
                                <a asp-action="Edit" asp-route-id="@p.MaPhong" class="btn btn-sm btn-warning text-dark"><i class="bi bi-pencil-square"></i> Đổi tên</a>
                                <a asp-action="Delete" asp-route-id="@p.MaPhong" class="btn btn-sm btn-danger"><i class="bi bi-trash"></i> Xóa</a>
                            </div>
                        </td>
                    </tr>
                }
            } else {
                <tr><td colspan="5" class="text-center text-muted">Chưa có phòng chiếu nào.</td></tr>
            }
        </tbody>
    </table>
</div>

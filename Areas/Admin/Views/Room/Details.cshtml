@model MiniCinema.Models.PhongChieu
@{ ViewData["Title"] = "Chi Tiết Phòng"; }
<div class="container mt-5">
    <div class="card shadow border-0 rounded-4 overflow-hidden">
        <div class="row g-0">
            <div class="col-md-12 p-5 text-center bg-dark text-white">
                <h1 class="display-1"><i class="bi bi-house-door-fill"></i></h1>
                <h2 class="mt-2 text-primary fw-bold">@Model.TenPhong</h2>
                <h5 class="text-light">Mã ID: @Model.MaPhong</h5>
            </div>
        </div>
        <div class="row p-5 justify-content-center text-center">
            <div class="col-md-4">
                <div class="p-4 border rounded-4 shadow-sm">
                    <h5 class="text-muted mb-2">Phân Loại</h5>
                    <h3 class="fw-bold"><span class="badge bg-secondary">@Model.LoaiPhong</span></h3>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4 border rounded-4 shadow-sm">
                    <h5 class="text-muted mb-2">Tổng Số Lượng Ghế</h5>
                    <h3 class="fw-bold text-success">@Model.TongSoGhe</h3>
                </div>
            </div>
        </div>
        <div class="row p-4 pt-0 text-center">
            <div class="col-md-12">
                <a asp-action="Edit" asp-route-id="@Model.MaPhong" class="btn btn-warning rounded-pill px-5 fw-bold"><i class="bi bi-pencil"></i> Chỉnh Sửa</a>
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-5 ms-2">Đóng</a>
            </div>
        </div>
    </div>
</div>

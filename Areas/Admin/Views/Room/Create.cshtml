@model MiniCinema.DTOs.RoomCreateDto
@{ ViewData["Title"] = "Tạo Phòng Mới"; }
<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <h3 class="mb-4 text-primary fw-bold text-center">TẠO PHÒNG CHIẾU TỰ ĐỘNG</h3>
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <form asp-action="Create">
                        <div class="mb-3">
                            <label class="form-label text-muted">Tên Phòng (VD: Cinema 1)</label>
                            <input asp-for="TenPhong" class="form-control rounded-pill px-3" id="TenPhong" />
                            <span asp-validation-for="TenPhong" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-muted">Mã Phòng (Gợi ý: P01, CINEMA1)</label>
                            <input asp-for="MaPhong" class="form-control rounded-pill px-3" id="MaPhong" />
                            <span asp-validation-for="MaPhong" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-muted">Loại Phòng (VD: 2D, 3D, IMAX)</label>
                            <select asp-for="LoaiPhong" class="form-select rounded-pill px-3">
                                <option value="">-- Chọn Loại Phòng --</option>
                                <option value="2D">Phòng chiếu 2D Tiêu Chuẩn</option>
                                <option value="3D">Phòng chiếu 3D</option>
                                <option value="IMAX">Phòng chiếu IMAX</option>
                            </select>
                            <span asp-validation-for="LoaiPhong" class="text-danger small"></span>
                        </div>
                        
                        <h5 class="mt-4 border-bottom pb-2">Thuật Toán Matrix Sinh Ghế</h5>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-muted">Số Hàng (A-Z)</label>
                                <input asp-for="SoHang" type="number" class="form-control rounded-pill px-3" placeholder="Tối đa 26" />
                                <span asp-validation-for="SoHang" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label text-muted">Kích thước 1 hàng</label>
                                <input asp-for="SoGheMoiHang" type="number" class="form-control rounded-pill px-3" placeholder="Số ghế trên 1 hàng" />
                                <span asp-validation-for="SoGheMoiHang" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="alert alert-info small mt-2">
                            <i class="bi bi-info-circle"></i> 
                            Hệ thống sẽ tự động vẽ tọa độ ghế từ A1 -> Z99. Ghế mặc định là Thường. 
                            Hai hàng cuối sẽ được gán là ghế VIP và hàng rìa cùng là Ghế Đôi.
                        </div>

                        <button type="submit" class="btn btn-primary w-100 btn-lg rounded-pill fw-bold mt-3">Xây Dựng Phòng Tiêu Chuẩn</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts { 
    @await Html.PartialAsync("_ValidationScriptsPartial") 
    <script>
        document.getElementById('TenPhong').addEventListener('input', function (e) {
            let ten = e.target.value;
            if (ten) {
                let code = ten.normalize("NFD").replace(/[\u0300-\u036f]/g, "")
                    .toUpperCase()
                    .replace(/Đ/g, "D")
                    .replace(/[^A-Z0-9]/g, "");
                
                // Nếu là "CINEMA1" thì chuyển thành "P1" hoặc giữ nguyên
                document.getElementById('MaPhong').value = code;
            }
        });
    </script>
}

@model MiniCinema.Models.SuatChieu
@{ ViewData["Title"] = "Xác nhận Hủy Lịch Chiếu"; }
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="alert alert-danger shadow rounded-4 p-4 text-center">
                <i class="bi bi-trash3-fill display-2 text-danger"></i>
                <h3 class="mt-3 fw-bold">XÁC NHẬN HỦY SUẤT CHIẾU</h3>
                <p class="fs-5 mt-2">Bạn sắp xóa vĩnh viễn Suất chiếu <strong>@Model.Phim?.TenPhim</strong> lúc <strong class="text-primary">@Model.GioBatDau.ToString("HH:mm dd/MM/yyyy")</strong> tại <strong>@Model.PhongChieu?.TenPhong</strong>.</p>
                
                @if(ViewBag.HasTickets == true) {
                    <div class="alert alert-danger mt-3 text-start fw-bold">
                        <i class="bi bi-shield-lock"></i> NGHIÊM TRỌNG: Suất chiếu này ĐÃ CÓ VÉ BÁN RA. Hành động XÓA sẽ tự động XÓA/HUỶ toàn bộ mã Vé điện tử đang nằm trên điện thoại của Khách hàng! Bạn có chắc mình muốn Đền Tiền Phạt?
                    </div>
                }

                <form asp-action="Delete" method="post" class="mt-4">
                    <input type="hidden" asp-for="MaSuatChieu" />
                    <button type="submit" class="btn btn-danger btn-lg rounded-pill px-5 fw-bold"><i class="bi bi-trash"></i> Đồng Ý Hủy</button>
                    <a asp-action="Index" class="btn btn-light btn-lg rounded-pill px-5 ms-2">Không, quay lại</a>
                </form>
            </div>
        </div>
    </div>
</div>

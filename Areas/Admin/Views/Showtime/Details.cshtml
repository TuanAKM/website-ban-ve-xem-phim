@model MiniCinema.Models.SuatChieu
@{ ViewData["Title"] = "Chi Tiết Suất Chiếu"; }
<div class="container mt-5">
    <div class="card shadow border-0 rounded-4 overflow-hidden">
        <div class="row g-0">
            <div class="col-md-5 bg-dark text-white p-5 d-flex flex-column justify-content-center align-items-center">
                <h1 class="display-3 text-warning"><i class="bi bi-clock-history"></i></h1>
                <h3 class="mt-3 text-center">@Model.GioBatDau.ToString("dd/MM/yyyy")</h3>
                <h1 class="display-4 fw-bold">@Model.GioBatDau.ToString("HH:mm")</h1>
            </div>
            <div class="col-md-7 p-5">
                <h2 class="text-primary border-bottom pb-2 mb-4">Thông Tin Lịch Chiếu</h2>
                <div class="row mb-3 fs-5">
                    <div class="col-sm-4 text-muted fw-bold">Phim:</div>
                    <div class="col-sm-8 fw-bold">@Model.Phim?.TenPhim</div>
                </div>
                <div class="row mb-3 fs-5">
                    <div class="col-sm-4 text-muted fw-bold">Phòng Số:</div>
                    <div class="col-sm-8"><span class="badge bg-secondary fs-5">@Model.PhongChieu?.TenPhong</span></div>
                </div>
                <div class="row mb-3 fs-5">
                    <div class="col-sm-4 text-muted fw-bold">Trạng Thái:</div>
                    <div class="col-sm-8"><span class="text-success fw-bold">ĐANG MỞ BÁN</span></div>
                </div>
                <div class="row mb-3 fs-5">
                    <div class="col-sm-4 text-muted fw-bold">Dự Kiến Xong:</div>
                    <div class="col-sm-8 text-danger">@Model.GioKetThuc.ToString("HH:mm")</div>
                </div>
                
                <div class="mt-4 pt-3 border-top">
                    <a asp-action="Edit" asp-route-id="@Model.MaSuatChieu" class="btn btn-warning rounded-pill px-4 fw-bold me-2"><i class="bi bi-pencil"></i> Đổi Lịch</a>
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Đóng</a>
                </div>
            </div>
        </div>
    </div>
</div>

@model MiniCinema.Models.SuatChieu

@{
    ViewData["Title"] = "Chọn ghế ngồi - " + Model.Phim!.TenPhim;
}

<div class="container mt-4">
    <h2 class="mb-4 text-primary">Chọn ghế ngồi - @Model.Phim.TenPhim</h2>
    <p class="text-muted"><i class="bi bi-clock"></i> Giờ chiếu: <strong>@Model.GioBatDau.ToString("dd/MM/yyyy HH:mm")</strong></p>

    @{
        decimal maxMultiLabel = 0.0m;
        string reason = "";
        var gBD = Model.GioBatDau;
        if (gBD.Hour >= 18 && gBD.Hour <= 23) { maxMultiLabel = 0.15m; reason = "Suất chiếu Tối"; }
        
        var hlds = new[] { (1, 1), (30, 4), (1, 5), (2, 9), (24, 12), (31, 12) };
        if (hlds.Contains((gBD.Day, gBD.Month))) {
            if (0.30m > maxMultiLabel) { maxMultiLabel = 0.30m; reason = "Ngày Lễ"; }
        } else if (gBD.DayOfWeek == DayOfWeek.Friday || gBD.DayOfWeek == DayOfWeek.Saturday || gBD.DayOfWeek == DayOfWeek.Sunday) {
            if (0.20m > maxMultiLabel) { maxMultiLabel = 0.20m; reason = "Cuối Tuần"; }
        }
    }
    @if (maxMultiLabel > 0)
    {
        <div class="alert alert-info py-2 shadow-sm d-inline-block rounded-pill ps-3 pe-4 fw-bold">
            <i class="bi bi-info-circle-fill text-primary"></i> Đang áp dụng Phụ thu +@((maxMultiLabel * 100).ToString("0"))% cho Khung giờ/Ngày: <span class="text-danger">@reason</span>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row">
        <div class="col-md-8">
            <div class="screen bg-dark text-white p-3 mb-5 text-center fw-bold rounded shadow-sm" style="letter-spacing: 5px;">MÀN HÌNH</div>
            <div class="seat-map d-flex flex-wrap justify-content-center gap-3">
                @if (Model.PhongChieu!.Ghes != null)
                {
                    var soldSeats = (List<string>)ViewBag.SoldSeats;
                    var lockedSeats = (List<string>)ViewBag.LockedSeats;

                    foreach (var ghe in Model.PhongChieu.Ghes.OrderBy(g => g.MaGhe))
                    {
                        string status = "Trong";
                        string colorClass = "bg-secondary"; // Trống

                        if (ghe.TrangThai == MiniCinema.Models.TrangThaiGhe.Hong)
                        {
                            status = "Hong";
                            colorClass = "bg-dark";
                        }
                        else if (soldSeats.Contains(ghe.MaGhe))
                        {
                            status = "DaBan";
                            colorClass = "bg-danger";
                        }
                        else if (lockedSeats.Contains(ghe.MaGhe))
                        {
                            status = "DangChon";
                            colorClass = "bg-warning";
                        }

                        decimal baseSeatPrice = 50000;
                        if (ghe.LoaiGhe == MiniCinema.Models.LoaiGhe.Vip) baseSeatPrice += 20000;
                        if (ghe.LoaiGhe == MiniCinema.Models.LoaiGhe.Doi) baseSeatPrice += 50000;

                        decimal maxMulti = 0.0m;
                        var gioBatDau = Model.GioBatDau;
                        if (gioBatDau.Hour >= 18 && gioBatDau.Hour <= 23) maxMulti = Math.Max(maxMulti, 0.15m);
                        
                        var holidays = new[] { (1, 1), (30, 4), (1, 5), (2, 9), (24, 12), (31, 12) };
                        if (holidays.Contains((gioBatDau.Day, gioBatDau.Month))) {
                            maxMulti = Math.Max(maxMulti, 0.30m);
                        } else if (gioBatDau.DayOfWeek == DayOfWeek.Friday ||
                                   gioBatDau.DayOfWeek == DayOfWeek.Saturday ||
                                   gioBatDau.DayOfWeek == DayOfWeek.Sunday) {
                            maxMulti = Math.Max(maxMulti, 0.20m);
                        }

                        int priceDetails = (int)(baseSeatPrice * (1.0m + maxMulti));

                        <div id="seat-@ghe.MaGhe"
                             class="seat p-1 text-center text-white cursor-pointer @colorClass rounded shadow-sm"
                             style="width: 70px; height: 60px; cursor: pointer; display: flex; flex-direction: column; align-items: center; justify-content: center; user-select: none; font-size: 0.8rem;"
                             data-id="@ghe.MaGhe"
                             data-status="@status"
                             data-price="@priceDetails"
                             onclick="toggleSeat('@ghe.MaGhe')">
                            @if (ghe.LoaiGhe == MiniCinema.Models.LoaiGhe.Vip)
                            {
                                <span style="font-size: 0.6rem; font-weight: bold; opacity: 0.8;">VIP</span>
                            }
                            else if (ghe.LoaiGhe == MiniCinema.Models.LoaiGhe.Doi)
                            {
                                <span style="font-size: 0.6rem; font-weight: bold; opacity: 0.8;">COUPLE</span>
                            }
                            <strong style="font-size: 1rem;">@ghe.MaGhe</strong>
                        </div>
                    }
                }
            </div>

            <div class="d-flex justify-content-center gap-4 mt-5">
                <div class="d-flex align-items-center gap-2"><div class="rounded bg-secondary" style="width: 20px; height: 20px;"></div> Trống</div>
                <div class="d-flex align-items-center gap-2"><div class="rounded bg-warning" style="width: 20px; height: 20px;"></div> Đang chọn (Người khác)</div>
                <div class="d-flex align-items-center gap-2"><div class="rounded bg-success" style="width: 20px; height: 20px;"></div> Đã đặt ghế</div>
                <div class="d-flex align-items-center gap-2"><div class="rounded bg-danger" style="width: 20px; height: 20px;"></div> Đã bán</div>
                <div class="d-flex align-items-center gap-2"><div class="rounded bg-dark" style="width: 20px; height: 20px;"></div> Hỏng</div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card p-4 shadow-sm border-0 bg-light rounded-4">
                <h4 class="mb-3 text-primary">Thông tin đặt vé</h4>
                
                <ul id="selectedSeatsList" class="list-group mb-3"></ul>
                
                <h5 class="mt-3">Tổng tiền: <span id="totalPrice" class="text-danger fw-bold fs-4">0</span> <span class="text-muted fs-6">VND</span></h5>
                
                <div id="timerContainer" class="d-none alert alert-warning mt-4 d-flex align-items-center gap-2">
                     <span class="spinner-border spinner-border-sm text-warning" role="status"></span>
                     <span>Thời gian giữ chỗ: <strong id="timer" class="fs-5">05:00</strong></span>
                </div>

                <div id="singleSeatWarning" class="alert alert-danger mt-3 d-none fw-bold" style="font-size: 0.9rem;">
                    <i class="bi bi-exclamation-triangle-fill"></i> Lỗi Lấp Đầy: Không được chừa lại 1 ghế trống kẹp ở giữa hoặc ở rìa mảng ghế!
                </div>

                <form asp-action="Payment" asp-controller="Booking" method="post" id="paymentForm">
                    <!-- Security token for antiforgery is auto-generated by asp-action tag helpers -->
                    <input type="hidden" name="SuatChieuId" value="@Model.MaSuatChieu" />
                    <!-- SelectedSeatIds inputs will be injected dynamically via JS -->
                    
                    @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                    {
                        <hr class="mt-4" />
                        <h5 class="text-success"><i class="bi bi-shop"></i> Xuất Vé Tại Quầy</h5>
                        <div class="mb-3">
                            <label class="form-label text-muted fw-bold" style="font-size:0.85rem">Số điện thoại khách (Bắt buộc):</label>
                            <input type="text" name="CustomerPhone" class="form-control" required placeholder="Nhập SĐT khách hàng..." id="txtCustomerPhone" />
                            <small class="text-muted d-block mt-1" style="font-size: 0.75rem">* Bắt buộc yêu cầu SĐT đối với khách vãng lai.</small>
                        </div>
                        <button type="button" onclick="submitStaffPayment()" class="btn btn-success w-100 py-2 fs-5 fw-bold rounded-3 shadow-sm" id="btnStaffPay" disabled>XUẤT VÉ TRỰC TIẾP</button>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-primary w-100 mt-4 py-2 fs-5 fw-bold rounded-3 shadow-sm" id="btnPay" disabled>XÁC NHẬN ĐẶT CHỖ</button>
                    }
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const hubConnection = new signalR.HubConnectionBuilder()
            .withUrl("/seathub")
            .build();
        
        hubConnection.on("SeatStatusChanged", function(seatId, newStatus) {
            const seatEl = document.getElementById("seat-" + seatId);
            if (!seatEl) return;
            
            seatEl.classList.remove("bg-secondary", "bg-warning", "bg-danger", "bg-dark", "bg-success");
            
            if (newStatus === "Trong") seatEl.classList.add("bg-secondary");
            if (newStatus === "DangChon") {
                if (selectedSeats.includes(seatId)) {
                    seatEl.classList.add("bg-success");
                } else {
                    seatEl.classList.add("bg-warning");
                }
            }
            if (newStatus === "DaBan") seatEl.classList.add("bg-danger");
            if (newStatus === "Hong") seatEl.classList.add("bg-dark");

            seatEl.dataset.status = newStatus;

            const idx = selectedSeats.indexOf(seatId);
            // Nếu phát sinh thay đổi từ người khác trên ghế mình đã chọn (trừ khi chính mình chọn thành công)
            if (idx > -1 && newStatus !== "DangChon" && newStatus !== "Trong") {
                 // Ghế này vừa có người mua xong (DaBan)
                 selectedSeats.splice(idx, 1);
                 updatePanel();
            }
            if (idx > -1 && newStatus === "Trong") {
                 // Hết hạn giữ chỗ 5 phút, tự động xóa khỏi danh sách chọn của mình
                 selectedSeats.splice(idx, 1);
                 updatePanel();
                 alert("Thời gian giữ chỗ ghế " + seatId + " đã hết!");
            }
        });

        hubConnection.start().then(() => {
            console.log("SignalR Connected");
            hubConnection.invoke("JoinShowtime", "@Model.MaSuatChieu");
        }).catch(err => console.error(err));

        let selectedSeats = [];
        let timerInterval = null;
        let countdown = 300; 

        async function toggleSeat(seatId) {
            const el = document.getElementById("seat-" + seatId);
            const status = el.dataset.status;

            if (status === "DaBan" || status === "Hong") {
                alert("Ghế này không khả dụng!");
                return;
            }

            const isSelected = selectedSeats.includes(seatId);

            if (isSelected) {
                // Eagerly remove to prevent SignalR conflict
                selectedSeats = selectedSeats.filter(s => s !== seatId);
                
                // Unlock
                const req = await fetch('/Booking/UnlockSeat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ShowtimeId: '@Model.MaSuatChieu', SeatId: seatId })
                });
                const res = await req.json();
                if (res.success) {
                    el.classList.remove("bg-success", "bg-warning", "bg-danger", "bg-dark");
                    el.classList.add("bg-secondary");
                    el.dataset.status = "Trong";
                } else {
                    selectedSeats.push(seatId); // Rollback
                }
            } else {
                if (status === "DangChon" && !selectedSeats.includes(seatId)) {
                    alert("Ghế đang được người khác chọn. Vui lòng chọn ghế khác.");
                    return;
                }

                // Eagerly push to prevent SignalR from thinking it's someone else's
                selectedSeats.push(seatId);

                // Lock
                const req = await fetch('/Booking/LockSeat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ShowtimeId: '@Model.MaSuatChieu', SeatId: seatId })
                });
                const res = await req.json();
                if (res.success) {
                    el.classList.remove("bg-secondary", "bg-warning", "bg-danger", "bg-dark");
                    el.classList.add("bg-success");
                    el.dataset.status = "DangChon";
                } else {
                    selectedSeats = selectedSeats.filter(s => s !== seatId); // Rollback
                    alert("Không thể chọn ghế này! Ghế có thể đã bị người khác chọn trước.");
                }
            }
            updatePanel();
        }

        function updatePanel() {
            const list = document.getElementById("selectedSeatsList");
            const btnPay = document.getElementById("btnPay");
            const form = document.getElementById("paymentForm");
            
            list.innerHTML = "";
            let total = 0;
            
            form.querySelectorAll("input[name='SelectedSeatIds']").forEach(i => i.remove());

            selectedSeats.forEach(s => {
                const el = document.getElementById("seat-" + s);
                const price = parseInt(el.dataset.price);
                total += price;

                const li = document.createElement("li");
                li.className = "list-group-item d-flex justify-content-between align-items-center";
                li.innerHTML = `Ghế <strong>${s}</strong> <span class="badge bg-primary rounded-pill">${price.toLocaleString()} đ</span>`;
                list.appendChild(li);

                const inp = document.createElement("input");
                inp.type = "hidden";
                inp.name = "SelectedSeatIds";
                inp.value = s;
                form.appendChild(inp);
            });

            document.getElementById("totalPrice").innerText = total.toLocaleString();

            let isValidGap = validateSingleEmptySeat();

            const btnStaffPay = document.getElementById("btnStaffPay");

            if (selectedSeats.length > 0) {
                if (!isValidGap) {
                    if (btnPay) btnPay.disabled = true;
                    if (btnStaffPay) btnStaffPay.disabled = true;
                    document.getElementById("singleSeatWarning").classList.remove("d-none");
                } else {
                    if (btnPay) btnPay.disabled = false;
                    if (btnStaffPay) btnStaffPay.disabled = false;
                    document.getElementById("singleSeatWarning").classList.add("d-none");
                }
                startTimer();
            } else {
                if (btnPay) btnPay.disabled = true;
                if (btnStaffPay) btnStaffPay.disabled = true;
                document.getElementById("singleSeatWarning").classList.add("d-none");
                stopTimer();
            }
        }

        const isStaffOrAdmin = @(User.IsInRole("Admin") || User.IsInRole("Staff") ? "true" : "false");

        function validateSingleEmptySeat() {
            if (!isStaffOrAdmin) return true; // Customer ko bị giới hạn
            
            const allSeatEls = document.querySelectorAll('.seat');
            let rows = {};
            
            allSeatEls.forEach(el => {
                const id = el.dataset.id;
                const row = id.charAt(0);
                const col = parseInt(id.substring(1));
                const status = el.dataset.status;
                const isSelected = selectedSeats.includes(id);
                
                if (!rows[row]) rows[row] = [];
                rows[row].push({ id, col, status, isSelected });
            });

            for (let r in rows) {
                const seats = rows[r].sort((a, b) => a.col - b.col);
                
                // Chỉ kiểm tra các hàng mà user đang có thao tác chọn ghế
                if (!seats.some(s => s.isSelected)) continue;

                const state = seats.map(s => {
                    if (s.isSelected) return "selected";
                    if (s.status === "DaBan" || s.status === "Hong" || s.status === "DangChon") return "occupied";
                    return "empty";
                });

                let emptyBlocks = [];
                let currentBlock = null;
                
                for (let i = 0; i < state.length; i++) {
                     if (state[i] === "empty") {
                          if (!currentBlock) currentBlock = { start: i, length: 0 };
                          currentBlock.length++;
                     } else {
                          if (currentBlock) {
                               emptyBlocks.push(currentBlock);
                               currentBlock = null;
                          }
                     }
                }
                if (currentBlock) emptyBlocks.push(currentBlock);

                for (let block of emptyBlocks) {
                     if (block.length === 1) {
                          let leftIdx = block.start - 1;
                          let rightIdx = block.start + 1;
                          
                          // Bỏ qua nếu ghế trống sát vách (không bị kẹp giữa 2 ghế)
                          if (leftIdx < 0 || rightIdx >= state.length) continue;
                          
                          let leftState = state[leftIdx];
                          let rightState = state[rightIdx];
                          
                          // Chỉ báo lỗi nếu lỗ hổng 1 ghế này do chính thao tác của User tạo ra (có cạnh là selected)
                          if (leftState === "selected" || rightState === "selected") {
                              return false;
                          }
                     }
                }
            }
            return true;
        }

        function submitStaffPayment() {
            const phoneInput = document.getElementById("txtCustomerPhone");
            if(!phoneInput.value) {
                alert("Bắt buộc phải nhập Số điện thoại khách hàng!");
                return;
            }
            var form = document.getElementById("paymentForm");
            form.action = '/Booking/StaffPayment';
            form.submit();
        }

        function startTimer() {
            if (timerInterval) return; 
            document.getElementById("timerContainer").classList.remove("d-none");
            countdown = 300;
            timerInterval = setInterval(() => {
                countdown--;
                if (countdown < 0) {
                    stopTimer();
                    alert("Đã hết 5 phút giữ chỗ! Vui lòng chọn lại ghế!");
                    window.location.reload();
                    return;
                }
                const m = Math.floor(countdown / 60).toString().padStart(2, '0');
                const s = (countdown % 60).toString().padStart(2, '0');
                document.getElementById("timer").innerText = `${m}:${s}`;
            }, 1000);
        }

        function stopTimer() {
            clearInterval(timerInterval);
            timerInterval = null;
            document.getElementById("timerContainer").classList.add("d-none");
            document.getElementById("timer").innerText = "05:00";
        }
    </script>
}
